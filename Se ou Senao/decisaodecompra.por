programa {
  funcao inicio() {
    
real saldo, valor

escreva("Qual o seu saldo do banco: ")
leia(saldo)

escreva("Qual o preço do item que quer comprar?")
leia(valor)


se(saldo >= valor){

escreva("Você pode comprar, parabéns seu burguês safado!")

}senao{ 
  escreva("Pobrezinho, vai ficar na vontade!")
}



























  }
}
