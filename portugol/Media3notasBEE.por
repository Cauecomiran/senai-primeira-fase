programa {
  funcao inicio() {
    
real notaA, notaB, notaC, media

escreva("Digite a nota da avaliação A: ")
leia(notaA)

escreva("Digite a nota da avaliação B: ")
leia(notaB)

escreva("Digite a nota da avaliação C: ")
leia(notaC)

media = (notaA + notaB + notaC) / 3

escreva("A média final entre suas notas é: " + media)




  }
}
