programa {
  funcao inicio() {

// indentificar e criar variaveis

real denis = 500
real salJunin = 350
real horas
real valorTotal
real lucro
// leitura

escreva("Quantas horas vai ser usado para terminar o trabalho? \n")
leia(horas)

// processar 


valorTotal = denis + (salJunin * horas)
lucro = valorTotal - denis




// apresentar


escreva("Valor total: " + valorTotal + " reais!")
escreva("\nSeu lucro foi de: " + lucro)


    
  }
}
