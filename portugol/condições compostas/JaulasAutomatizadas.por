programa {
  funcao inicio() {

real horario
inteiro visitantes

escreva("Quantos visitantes há no local? ")
leia(visitantes)

escreva("Que horas são? ")
leia(horario)

se(horario < 8 ou horario > 18 e visitantes == 0 ){
  escreva("Jaulas podem ser abertas!")
}senao{
  escreva("Por motivos de segurança, todas jaulas devem ficar fechadas!")
}





























    
  }
}
