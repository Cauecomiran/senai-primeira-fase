programa {
  funcao inicio() {

logico crachaValido, digitalReconhecida

escreva("O crachá está valido? ")
leia(crachaValido)

escreva("Digital foi reconhecida? ")
leia(digitalReconhecida)

se( digitalReconhecida e crachaValido == verdadeiro ){
  escreva("Acesso permitido!")

} senao{
  escreva("Acesso negado!")
}





















  }
}
