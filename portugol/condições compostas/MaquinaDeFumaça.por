programa {
  funcao inicio() {
    
inteiro criancaPequena
real velocidadeVento

escreva("Digite quantas crianças pequenas por perto: ")
leia(criancaPequena)

escreva("Digite qual a velociade do vento no salão: (m/s) ")
leia(velocidadeVento)

se(criancaPequena == 0 e velocidadeVento >= 0.5){
  escreva("Fumaça liberada, que os mistérios comecem!!!")
}senao{
  escreva("Fumaça bloqueada, aguardando condições ideais!!!")
}




















  }
}
