programa {
  funcao inicio() {
    
 inteiro numero1, numero2

escreva("Digite o numero 1: ")
leia(numero1)

escreva("Digite o número 2: ")
leia(numero2)

se(numero1 > numero2)
  {escreva("O número 1 é maior!!!")}
senao se( numero1 < numero2)
  {escreva("O número 2 é maior!!!")}
senao se( numero1 == numero2)
  {escreva("Os numeros são iguais!!!")}




  }
}
