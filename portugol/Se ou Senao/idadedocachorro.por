programa {
  funcao inicio() {

inteiro idadeDog, idadeHumana

escreva("Digite a idade do seu cachorro: ")
leia(idadeDog)

idadeHumana = idadeDog * 7

se(idadeHumana >= 60 ){
  escreva("Ja pode aposentar, precisa de um descanso!")
}senao{
  escreva("Ishi, tadinho, ainda precisa trabalhar!")
}
    
  }
}
