programa {
  funcao inicio() {

// indentificar e criar variaveis
real valorPc
real valorVnd

// leitura de dados

escreva("Quanto você pagou pela peça? ")
  leia(valorPc)

//processar dados

valorVnd = 3 * valorPc

// apresentar

escreva("O valor de venda vai ser de: " + valorVnd + " Reais.")





    
  }
}
