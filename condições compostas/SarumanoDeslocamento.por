programa {
  funcao inicio() {
    
    cadeia gripado
    inteiro minutosViagem

    escreva("Sarumano está gripado? ")
    leia(gripado)

    escreva("Quantos minutos em viagem? ")
    leia(minutosViagem)

    se( minutosViagem < 45 e gripado == "nao"){
      escreva("Viagem autorizada, rumo ao show!!!")
    }senao{
      escreva("Deslocamento inviável. Melhor recusar este evento!")
    }























  }
}
