programa {
  funcao inicio() {

  real show
  real valorBomba
 

    escreva("Quantos shows serão feitos nessa turne?")
      leia(show)

    escreva("Qual o valor de cada bomba?")
      leia(valorBomba)

  show = show * 7
  valorBomba = valorBomba * show

    escreva("Vão ser preciso " + show + "\n E vai gastar: " + valorBomba)
    


  

    
  }
}
